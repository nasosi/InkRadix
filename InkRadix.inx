<inkscape-extension>

  <name>Radical Pie Equation</name>
  <id>nasos.inkradix</id>

  <effect>
  
    <object-type> all </object-type>
    
    <effects-menu>
    
      <submenu name="Text"/>
      
    </effects-menu>
    
  </effect>

  <menu-tip>Open Radical Pie Equation editor for selected objects</menu-tip>

  <script>
  
    <command location="inx" interpreter="python">InkRadix.py</command>
    
  </script>
  
</inkscape-extension>
